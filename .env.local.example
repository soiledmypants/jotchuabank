# =============================================================
#  Copy this file to .env.local and fill in your values.
#  .env.local is NEVER committed to git.
# =============================================================

# ---- Token addresses (safe to expose client-side) -----------

# Your $JOTCHUABANK token mint address (from pump.fun)
NEXT_PUBLIC_MAIN_TOKEN_MINT=PASTE_JOTCHUABANK_MINT_HERE

# The reward token you're buying with fees and airdropping
NEXT_PUBLIC_REWARD_TOKEN_MINT=PASTE_REWARD_TOKEN_MINT_HERE

# Ticker symbol shown in the UI (e.g. $JOTCHUA)
NEXT_PUBLIC_REWARD_TOKEN_SYMBOL=$JOTCHUA

# The wallet address that collects trading fees
NEXT_PUBLIC_FEE_WALLET=PASTE_FEE_WALLET_HERE

# Solana RPC endpoint — get a free key at helius.dev for best results
# Format: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# ---- Server-side secrets (NEVER expose these) ---------------

# Secret key to protect the POST /api/airdrop endpoint
# Generate one: openssl rand -hex 32
AIRDROP_API_KEY=your-very-long-secret-key-here

# Base58-encoded private key of the fee wallet
# This wallet must hold the reward token to distribute
# Example (Phantom): export private key → copy the base58 string
AIRDROP_WALLET_PRIVATE_KEY=your-base58-private-key-here
